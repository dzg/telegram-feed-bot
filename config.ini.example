[telephon]
api_id = YOUR_API_ID
api_hash = YOUR_API_HASH
bot_token = YOUR_BOTFATHER_BOT_TOKEN
username = your_info
user_id = YOUR_MAIN_ACCOUNT_USER_ID
command_user_ids = YOUR_OTHER_ACCOUNT_IDS_COMMA_SEPARATED
telephon_user_id = YOUR_SECONDARY_ACCOUNT_USER_ID

[settings]
target_channel = https://t.me/your_target_channel
# Timezone for the "🕓 original time" footer on /pull backfilled posts (IANA name),
# e.g. America/New_York (ET), America/Chicago (CT), Asia/Jerusalem.
display_timezone = America/New_York
# How often (seconds) to poll each source channel for new posts (min 30).
poll_interval = 120
source_chats =
    abualiexpress
    aharonyediotnews
    CaptainLoui
    amitseg
    yediotnews25
    eye_on_ME
rss_feeds =
    https://rss.app/feeds/EXAMPLE.xml

[filters]
# Modular text cleanup. '*' is a wildcard (any run of characters); everything
# else is matched literally, case-insensitively. Edit + restart to apply.
#   drop_lines  — remove any whole line that matches (best for promo footers)
#   remove_text — delete just the matched substring, keep the rest of the line
drop_lines =
    *abualiexpress.com/*
    *Click here to respond to the article*
    *Click here to comment on the article*
    New! *Aharon Yediot* App
    Download for iPhone:*
    Download for Android:*
remove_text =
    https://t.me/yediotnews25
# drop_lines_regex / remove_text_regex use REAL regex (not wildcards) for precise
# patterns — e.g. strip a standalone comment-count line like "12 comments"/"One comment":
drop_lines_regex =
    ^\s*(\d+|one)\s+comments?\s*$
remove_text_regex =

[ad_detection]
# Whole-message drop rules ('*' = wildcard, literal + case-insensitive otherwise).
#   text_markers   — drop the message if its text matches any of these
#   button_markers — drop the message if any inline button label matches
text_markers =
    תוכן שיווקי
    Here are today's top stories on Telegram
button_markers =
    לפרסום
